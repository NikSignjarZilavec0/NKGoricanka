# --- NK Goričanka — environment variables ---
# Copy to .env and adjust. docker-compose reads this file automatically.

# Express server port (host + container)
PORT=5000

# MongoDB connection (service name "mongo" inside the docker network)
MONGO_URI=mongodb://mongo:27017/nkgoricanka

# Secret used to sign session cookies — CHANGE THIS in production!
SESSION_SECRET=please-change-this-to-a-long-random-string

# Default administrator, created on first start if no user exists
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Base URL used to build absolute Open Graph / canonical URLs (no trailing slash)
# In production set this to your real domain, e.g. https://nkgoricanka.si
SITE_URL=http://localhost:5000

# Set to true ONLY when served over HTTPS (e.g. behind the Caddy reverse proxy).
# Marks the session cookie as Secure. Keep false for plain-HTTP / local dev.
SECURE_COOKIES=false

# Node environment
NODE_ENV=production
